# --- Build Stage ---
FROM node:20-alpine AS builder

RUN npm install -g pnpm@9

WORKDIR /app

COPY frontend/ ./

RUN pnpm install --frozen-lockfile

RUN pnpm build

# --- Final Stage ---
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY deployments/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
